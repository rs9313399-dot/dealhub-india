# Canonical site URL for sitemap, canonical tags, JSON-LD, and RSS.
NEXT_PUBLIC_SITE_URL=https://dealhub-india.vercel.app

# Turso database (SQLite serverless) — required for production on Vercel
# 1. Sign up free at https://turso.tech
# 2. Create a DB: turso db create dealhub-india
# 3. Get URL: turso db show dealhub-india --url
# 4. Get token: turso db tokens create dealhub-india
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Local dev only (SQLite file — ignored if TURSO_DATABASE_URL is set)
DATABASE_URL=file:./dev.db
